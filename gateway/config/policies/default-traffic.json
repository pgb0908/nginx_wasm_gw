{
  "apiVersion": "iip.gateway/v1alpha1",
  "kind": "Policy",
  "metadata": {
    "name": "default-traffic"
  },
  "spec": {
    "targetRef": {
      "kind": "Router",
      "name": "*"
    },
    "order": 10,
    "config": {
      "rateLimit": {
        "quota": { "limit": 10, "window": "1s" }
      }
    }
  }
}
