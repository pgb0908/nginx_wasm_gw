{
  "apiVersion": "iip.gateway/v1alpha1",
  "kind": "Policy",
  "metadata": {
    "name": "default-security"
  },
  "spec": {
    "targetRef": {
      "kind": "Router",
      "name": "*"
    },
    "order": 5,
    "config": {
      "apiKey": {
        "header": "X-API-Key",
        "keys": ["secret-key-1", "secret-key-2", "rl-test-key"]
      }
    }
  }
}
